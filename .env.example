# Network Configuration
NETWORK_NAME=app-network

# Redis Configuration
REDIS_CONTAINER_NAME=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_VOLUME_NAME=redis_data
REDIS_HC_INTERVAL=30s
REDIS_HC_TIMEOUT=10s
REDIS_HC_RETRIES=3
REDIS_HC_START_PERIOD=5s

# API Configuration
API_CONTAINER_NAME=api
API_PORT=8000
API_URL=http://api:8000

# Frontend Configuration
FRONTEND_CONTAINER_NAME=frontend
FRONTEND_PORT=3000

# Worker Configuration
WORKER_CONTAINER_NAME=worker

# Global Restart Policy
RESTART_POLICY=unless-stopped

# Resource Limits - Redis
REDIS_CPU_LIMIT=0.5
REDIS_CPU_RESERVE=0.25
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVE=128M

# Resource Limits - API
API_CPU_LIMIT=1.0
API_CPU_RESERVE=0.5
API_MEMORY_LIMIT=512M
API_MEMORY_RESERVE=256M

# Resource Limits - Frontend
FRONTEND_CPU_LIMIT=0.5
FRONTEND_CPU_RESERVE=0.25
FRONTEND_MEMORY_LIMIT=256M
FRONTEND_MEMORY_RESERVE=128M

# Resource Limits - Worker
WORKER_CPU_LIMIT=0.5
WORKER_CPU_RESERVE=0.25
WORKER_MEMORY_LIMIT=256M
WORKER_MEMORY_RESERVE=128M
